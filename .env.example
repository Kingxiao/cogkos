# CogKOS Environment Configuration
# Copy to .env and fill in actual values: cp .env.example .env

# ============================================================
# REQUIRED — CogKOS will not start without these
# ============================================================

# PostgreSQL (with pgvector extension)
DATABASE_URL=postgres://cogkos:cogkos_dev@localhost:5432/cogkos

# FalkorDB (Redis-protocol compatible graph database)
FALKORDB_URL=redis://localhost:6379
FALKORDB_GRAPH=cogkos

# MCP Server
MCP_TRANSPORT=http
MCP_HOST=0.0.0.0
MCP_PORT=3000

# Health/Metrics endpoint
HEALTH_PORT=8081

# ============================================================
# RECOMMENDED — Semantic search quality depends on real embeddings
# ============================================================

# Embedding API (priority: EMBEDDING_API_KEY > API_302_KEY > OPENAI_API_KEY)
# Without this, CogKOS falls back to pseudo-vectors (reduced search quality)
API_302_KEY=
EMBEDDING_BASE_URL=https://api.302.ai/v1
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_PROVIDER=openai

# Or use a dedicated embedding key (overrides above)
# EMBEDDING_API_KEY=

# ============================================================
# OPTIONAL — LLM for predictions, S3 for document storage
# ============================================================

# LLM (used for predictions and classification, not required for core function)
OPENAI_API_KEY=
LLM_PROVIDER=openai
LLM_BASE_URL=
LLM_MODEL=gpt-4

# S3/SeaweedFS (for document upload via upload_document tool)
S3_ENDPOINT=http://localhost:8333
S3_ACCESS_KEY=cogkos
S3_SECRET_KEY=cogkos_dev_secret_key
S3_BUCKET=cogkos-docs
S3_REGION=us-east-1

# Local filesystem fallback for object storage (no S3 needed)
# LOCAL_STORAGE_PATH=./data/objects

# ============================================================
# DEVELOPMENT — Only for local dev / dogfooding
# ============================================================

# Logging: RUST_LOG controls level, LOG_FORMAT=json for structured output
RUST_LOG=info
LOG_FORMAT=json

# Default API key for quick start (bypasses admin CLI key creation)
# Set this to any string to use as a dev API key without running cogkos-admin
# Tenant ID for the default API key (defaults to "default" if not set)
DEFAULT_MCP_TENANT=
DEFAULT_MCP_API_KEY=
