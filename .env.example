# 环境变量模板
# 复制为 .env 并填写实际值

# PostgreSQL
DATABASE_URL=postgres://cogkos:cogkos_dev@localhost:5432/cogkos

# FalkorDB (Redis协议)
FALKORDB_URL=redis://localhost:6379
FALKORDB_GRAPH=cogkos

# S3/SeaweedFS
S3_ENDPOINT=http://localhost:8333
S3_ACCESS_KEY=cogkos
S3_SECRET_KEY=cogkos_dev_secret_key
S3_BUCKET=cogkos-docs
S3_REGION=us-east-1

# MCP Server
MCP_HOST=0.0.0.0
MCP_PORT=3000

# Health/Metrics endpoint
HEALTH_PORT=8080

# 日志: RUST_LOG 控制级别, LOG_FORMAT=json 启用 JSON 输出
RUST_LOG=info
LOG_FORMAT=json

# 嵌入模型配置（优先级：EMBEDDING_API_KEY > API_302_KEY > OPENAI_API_KEY）
# 默认使用 302.ai 的 text-embedding-3-large
API_302_KEY=
EMBEDDING_BASE_URL=https://api.302.ai/v1
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_PROVIDER=openai

# Embedding 独立配置（可选，覆盖上述默认）
EMBEDDING_API_KEY=

# LLM 配置
OPENAI_API_KEY=
LLM_PROVIDER=openai
LLM_BASE_URL=
LLM_MODEL=gpt-4
