# CogKOS Environment Configuration
# Copy to .env and fill in actual values: cp .env.example .env

# ============================================================
# SECURITY MODE — Controls all security behaviors
# ============================================================
# "development" (default): convenience mode, dev API key works, CORS open
# "production": security enforced, dev key disabled, CORS restricted
# COGKOS_ENV=development

# Production-only: restrict CORS origins (comma-separated)
# CORS_ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com

# ============================================================
# REQUIRED — CogKOS will not start without these
# ============================================================

# PostgreSQL (with pgvector extension)
DATABASE_URL=postgres://cogkos:cogkos_dev@localhost:5435/cogkos

# FalkorDB (Redis-protocol compatible graph database)
FALKORDB_URL=redis://localhost:6381
FALKORDB_GRAPH=cogkos

# MCP Server
MCP_TRANSPORT=http
MCP_HOST=0.0.0.0
MCP_PORT=3000

# Health/Metrics endpoint
HEALTH_PORT=8081

# ============================================================
# RECOMMENDED — Semantic search quality depends on real embeddings
# ============================================================

# Embedding model configuration
# Supported: any OpenAI-compatible /v1/embeddings endpoint
# NOT supported: Anthropic (no embeddings API)
#
# Option 1: Local BGE-M3 via TEI (recommended — free, fast, multilingual)
#   EMBEDDING_MODEL=BAAI/bge-m3
#   EMBEDDING_BASE_URL=http://localhost:8090/v1
#   No API key needed for local TEI — leave EMBEDDING_API_KEY empty
#   Start TEI: docker compose -f docker-compose.bge-m3.yml up -d
#
# Option 2: BGE-M3 via DeepInfra (cloud, pay-per-use)
#   EMBEDDING_MODEL=BAAI/bge-m3
#   EMBEDDING_BASE_URL=https://api.deepinfra.com/v1/openai
#   EMBEDDING_API_KEY=your_deepinfra_key_here
#
# Option 3: OpenAI text-embedding-3-large via 302.ai (cloud, pay-per-use)
#   EMBEDDING_MODEL=text-embedding-3-large
#   EMBEDDING_BASE_URL=https://api.302.ai/v1
#   API_302_KEY=your_302ai_key_here
#
# Without any embedding config, CogKOS falls back to pseudo-vectors (reduced search quality)
# API key priority: EMBEDDING_API_KEY > API_302_KEY > OPENAI_API_KEY
EMBEDDING_BASE_URL=http://localhost:8090/v1
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_PROVIDER=openai
EMBEDDING_API_KEY=
API_302_KEY=

# ============================================================
# OPTIONAL — LLM for predictions, S3 for document storage
# ============================================================

# LLM (used for predictions and classification, not required for core function)
# LLM_API_KEY takes priority over provider-specific keys for test binaries
LLM_API_KEY=
OPENAI_API_KEY=
LLM_PROVIDER=openai
LLM_BASE_URL=
LLM_MODEL=gpt-4

# Image understanding model (used by cogkos-ingest image parser)
# IMAGE_LLM_MODEL=gpt-4o

# S3/SeaweedFS (for document upload via upload_document tool)
# S3_* are the canonical vars. AWS_* are accepted as fallback for standard SDK compat:
#   S3_REGION       > AWS_REGION > AWS_DEFAULT_REGION  (default: us-east-1)
#   S3_ACCESS_KEY   > AWS_ACCESS_KEY_ID
#   S3_SECRET_KEY   > AWS_SECRET_ACCESS_KEY
S3_ENDPOINT=http://localhost:8333
S3_ACCESS_KEY=cogkos
S3_SECRET_KEY=cogkos_dev_secret_key
S3_BUCKET=cogkos-docs
S3_REGION=us-east-1

# Local filesystem fallback for object storage (no S3 needed)
LOCAL_STORAGE_PATH=./data/objects

# ============================================================
# DEVELOPMENT — Only for local dev / dogfooding
# ============================================================

# Logging: RUST_LOG controls level, LOG_FORMAT=json for structured output
RUST_LOG=info
LOG_FORMAT=json

# Default API key for quick start (bypasses admin CLI key creation)
# Set this to any string to use as a dev API key without running cogkos-admin
# Tenant ID for the default API key (defaults to "default" if not set)
DEFAULT_MCP_TENANT=
DEFAULT_MCP_API_KEY=

# Auth cache TTL in seconds (how long before re-validating API keys)
AUTH_CACHE_TTL=300

# ============================================================
# ADVANCED — Tuning parameters (defaults work for most setups)
# ============================================================

# Query cache TTL override
# CACHE_TTL_SECONDS=3600

# System 1 (fast-path) thresholds
# SYSTEM1_CONFIDENCE_THRESHOLD=0.7
# SYSTEM1_MIN_HITS=3
# SYSTEM1_SUCCESS_RATE_THRESHOLD=0.8

# Authority tier weight in query result ranking (0.0=disabled, 0.2=default)
# Higher values prioritize Business/Canonical knowledge over Agent observations
# MERGE_AUTHORITY_WEIGHT=0.2

# Feedback quality weight in query result ranking (0.0=disabled, 0.25=default)
# Higher values prioritize knowledge confirmed by positive agent feedback
# MERGE_FEEDBACK_WEIGHT=0.25

# Workflow engine (optional, template matching + LLM planning)
# ENABLE_WORKFLOW_ENGINE=true

# Conflict notification webhook (optional, fire-and-forget)
# CogKOS will POST a JSON payload when conflicts are detected.
# Supports any endpoint accepting JSON POST (Slack, Feishu, custom).
# CONFLICT_WEBHOOK_URL=https://hooks.slack.com/services/xxx

# RSS/External polling (used by background poller)
# POLLING_TENANT_ID=default
# POLLING_INTERVAL_SECS=3600
# POLLING_MAX_ITEMS=20
# RSS_FEEDS=

# Activation weight batch flush interval (default: 5 seconds)
# ACTIVATION_FLUSH_INTERVAL_SECS=5
